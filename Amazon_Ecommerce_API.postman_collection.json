{
  "info": {
    "_postman_id": "amazon-ecommerce-api-collection",
    "name": "Amazon E-Commerce API",
    "description": "Complete API collection for Amazon E-Commerce Backend built with Node.js, Express and MongoDB Atlas.\n\n**Base URL:** `http://localhost:5001/api/v1`\n\n**Auth:** Login first and the token is auto-saved to environment variable `access_token`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5001/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Basic Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
            "description": "Basic liveness check. Returns server uptime and environment."
          }
        },
        {
          "name": "Detailed Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health/detailed", "host": ["{{base_url}}"], "path": ["health", "detailed"] },
            "description": "Returns server status + MongoDB connection state."
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Raushan Kumar\",\n  \"email\": \"raushan@example.com\",\n  \"password\": \"Raushan@123\",\n  \"role\": \"customer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Register a new user. Role can be: customer, seller, admin"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.environment.set('access_token', res.data.accessToken);",
                  "  console.log('✅ Token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"raushan@example.com\",\n  \"password\": \"Raushan@123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login and get access token. Token is auto-saved to {{access_token}} environment variable."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your_refresh_token_here\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Get a new access token using the refresh token."
          }
        }
      ]
    },
    {
      "name": "📦 Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?page=1&limit=10&minPrice=100&maxPrice=5000&minRating=3&inStock=true&sortBy=price&sortOrder=asc",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "minPrice", "value": "100" },
                { "key": "maxPrice", "value": "5000" },
                { "key": "minRating", "value": "3" },
                { "key": "inStock", "value": "true" },
                { "key": "sortBy", "value": "price" },
                { "key": "sortOrder", "value": "asc" }
              ]
            },
            "description": "List all products with optional filters and pagination."
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/products/:id", "host": ["{{base_url}}"], "path": ["products", ":id"], "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }] },
            "description": "Get a single product by its MongoDB _id."
          }
        },
        {
          "name": "Get Related Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/products/:id/related", "host": ["{{base_url}}"], "path": ["products", ":id", "related"], "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }] },
            "description": "Get related products by category."
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Wireless Headphones Pro\",\n  \"description\": \"Premium noise-cancelling over-ear wireless headphones with 30hr battery\",\n  \"price\": 2999,\n  \"discountPercentage\": 10,\n  \"stock\": 50,\n  \"category\": \"CATEGORY_ID_HERE\",\n  \"images\": [\"https://example.com/headphones.jpg\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new product. Requires Seller or Admin role."
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/products/:id", "host": ["{{base_url}}"], "path": ["products", ":id"], "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 2599,\n  \"stock\": 45,\n  \"discountPercentage\": 15\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update product details. Seller can only update own products."
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/products/:id", "host": ["{{base_url}}"], "path": ["products", ":id"], "variable": [{ "key": "id", "value": "PRODUCT_ID_HERE" }] },
            "description": "Delete a product. Admin only."
          }
        }
      ]
    },
